{
  "env": {
    "AEM_HOST": "localhost",
    "AEM_PORT_AUTHOR": "4502",
    "AEM_PORT_PUBLISH": "4503",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(mvn *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(npm *)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rd /s *)",
      "Bash(Remove-Item * -Recurse*)",
      "Bash(del /f /s *)",
      "Bash(curl *admin:admin*)",
      "Bash(mvn deploy*)",
      "Bash(mvn release:*)",
      "Bash(git push --force*)"
    ],
    "ask": [
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git reset *)",
      "Bash(git stash *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && (python3 .claude/hooks/guard-sensitive-files.py || python .claude/hooks/guard-sensitive-files.py)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && (python3 .claude/hooks/guard-bash-deploy.py || python .claude/hooks/guard-bash-deploy.py)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && (python3 .claude/hooks/post-format.py || python .claude/hooks/post-format.py)"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && (python3 .claude/hooks/post-dispatcher-validate.py || python .claude/hooks/post-dispatcher-validate.py)"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && (python3 .claude/hooks/post-tool-failure.py || python .claude/hooks/post-tool-failure.py)"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && (python3 .claude/hooks/post-compact.py || python .claude/hooks/post-compact.py)"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && (python3 .claude/hooks/teammate-idle.py || python .claude/hooks/teammate-idle.py)"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && (python3 .claude/hooks/subagent-stopped.py || python .claude/hooks/subagent-stopped.py)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && (python3 .claude/hooks/post-stop.py || python .claude/hooks/post-stop.py)"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "jdtls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true
  }
}
